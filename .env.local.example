# ==============================================================================
# Isaac Assist — Local Environment Configuration
# ==============================================================================
#
# Copy this file to .env.local and fill in YOUR values.
# This file is loaded by the service and is git-ignored so your secrets stay local.
#
# Priority: .env.local > service/isaac_assist_service/.env > .env (root)
#
# ==============================================================================

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which LLM backend to use for chat:
#   "anthropic" — Claude (recommended, best tool-calling)
#   "openai"    — OpenAI-compatible (GPT, Grok, local vLLM)
#   "ollama"    — Local Ollama instance
#   "gemini"    — Google Gemini
LLM_MODE=anthropic

# Model name for the selected provider
CLOUD_MODEL_NAME=claude-opus-4-7
# LOCAL_MODEL_NAME=qwen3.6:latest      # Uncomment for Ollama mode

# ── API Keys ──────────────────────────────────────────────────────────────────
# Only the key for your chosen LLM_MODE is required.
# NEVER commit real keys — this file is git-ignored.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx
# GEMINI_API_KEY=xxxxxxxxxxxx
# GROK_API_KEY=xai-xxxxxxxxxxxx

# ── OpenAI-Compatible Base URL ────────────────────────────────────────────────
# Change this for Grok, local vLLM, or any OpenAI-compatible endpoint:
#   Grok:       https://api.x.ai/v1
#   Local vLLM: http://localhost:8080/v1
OPENAI_API_BASE=https://api.openai.com/v1

# Local mode uses Ollama's OpenAI-compatible endpoint. Keep this separate from
# OPENAI_API_BASE so cloud and local modes can coexist.
OLLAMA_OPENAI_BASE=http://localhost:11434/v1

# ── Cosmos 3 Scene Proposals (Optional) ──────────────────────────────────────
# Used by the future Cosmos runtime provider. The committed canvas route already
# accepts structured CosmosSceneObservation JSON at:
#   POST /api/v1/canvas/{session_id}/cosmos/propose
# COSMOS3_MODE=disabled                 # disabled | local | nim | vllm
# COSMOS3_REASONER_BASE_URL=http://localhost:8081/v1
# COSMOS3_REASONER_MODEL=Cosmos3-Nano
# COSMOS3_API_KEY=xxxxxxxxxxxx          # Optional; can also use NGC_API_KEY
# COSMOS3_GENERATOR_BASE_URL=http://localhost:8082/v1
# COSMOS3_GENERATOR_MODEL=Cosmos3-Super-Text2Image

# ── Remote Scale Providers (Optional) ────────────────────────────────────────
# Allows expensive jobs to run on DGX Spark, Brev, or IsaacAutomator while the
# local workstation keeps Isaac Sim and the extension responsive.
# ISAAC_ASSIST_SCALE_PROVIDER=local      # local | dgx_spark | brev | isaac_automator
# DGX_SPARK_COSMOS_BASE_URL=http://dgx-spark.local:8081/v1
# BREV_API_KEY=xxxxxxxxxxxx
# BREV_PROJECT_ID=xxxxxxxxxxxx
# BREV_TEMPLATE_ID=xxxxxxxxxxxx
# ISAAC_AUTOMATOR_ROOT=/home/your_user/IsaacAutomator
# ISAAC_AUTOMATOR_CLOUD=aws              # aws | gcp | azure | alicloud
# ISAAC_AUTOMATOR_DEPLOYMENT=isaac-assist-remote
# ISAAC_AUTOMATOR_ISAACSIM_REF=v6.0.0-dev2
# ISAAC_AUTOMATOR_ISAACLAB_REF=v3.0.0-beta

# ── Assets ────────────────────────────────────────────────────────────────────
# Path to your Isaac Sim asset library (robots, environments, objects).
# This is where robot USD files live. Supports two modes:
#
# Option A — Local filesystem (offline, recommended):
#   Download assets from Nucleus or the Isaac Sim Asset Browser,
#   place them in a folder, and set the path here.
ASSETS_ROOT_PATH=/home/your_user/Desktop/assets
#
# Option B — NVIDIA Omniverse Nucleus server:
#   If you have a Nucleus server running (local or cloud), point to it directly.
#   Requires Nucleus to be accessible from the machine running Isaac Sim.
# ASSETS_ROOT_PATH=omniverse://localhost/NVIDIA/Assets/Isaac/5.1
#
# Option C — NVIDIA NGC / S3 hosted assets:
#   Only works if your network allows direct S3 access (not behind a firewall).
# ASSETS_ROOT_PATH=https://omniverse-content-production.s3-us-west-2.amazonaws.com/Assets/Isaac/5.1

# Subdirectory within ASSETS_ROOT_PATH that contains robot USD files.
# Default: "Collected_Robots" (matches the Isaac Sim asset download structure)
ASSETS_ROBOTS_SUBDIR=Collected_Robots

# ── Isaac Sim Path ────────────────────────────────────────────────────────────
# Only needed if the launch script can't auto-detect your installation.
# ISAAC_RUNTIME_PROFILE=isaacsim-6.0
# ISAAC_VERSION=6.0
# ISAAC_SIM_PATH=/home/your_user/isaac-sim/isaac-sim-standalone-5.1.0-linux-x86_64
# ISAAC_SIM_ROOT=/home/your_user/IsaacSim/_build/linux-x86_64/release
# ISAAC_ASSIST_EXT_FOLDER=/home/your_user/Omniverse_Nemotron_Ext/exts/isaac_6.0

# ── Isaac Lab Path ────────────────────────────────────────────────────────────
# Only needed for ./launch_isaac.sh --lab or Isaac Lab-backed workflows.
# ISAAC_LAB_ROOT=/home/your_user/open_arm_10Things/IsaacLab

# ── LiveKit (Optional — voice/vision features) ───────────────────────────────
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# ── Fine-Tuning Data Collection ──────────────────────────────────────────────
# Set to "true" to log approved code patches for fine-tuning data collection.
# Data is stored locally in workspace/finetune_exports/ and never sent externally.
CONTRIBUTE_DATA=false

# Local dev convenience. With true, code patch tools execute immediately through
# Kit RPC /exec_sync. Keep false when using a human approval dialog.
AUTO_APPROVE=false

# Recommended for Isaac extension sessions. Uvicorn auto-reload can wedge while
# the extension has open SSE streams.
ISAAC_ASSIST_RELOAD=0

# ── Image-to-3D Generation (Phase 6B) ────────────────────────────────────────
# Backend for converting uploaded images to 3D USD models.
# Options:
#   "triposr"     — TripoSR (local GPU, fast, ~10s per model)
#   "instantmesh" — InstantMesh (local GPU, higher quality, ~60s)
#   "trellis"     — Trellis (local GPU, state-of-art)
#   "api"         — External HTTP API (set IMAGE_TO_3D_API_URL below)
# IMAGE_TO_3D_BACKEND=triposr
# IMAGE_TO_3D_API_URL=http://localhost:8090/generate

# ── Nucleus Server (Optional — for asset catalog search) ─────────────────────
# If you have a Nucleus server, the scene builder can search it for assets.
# NUCLEUS_SERVER=omniverse://localhost
