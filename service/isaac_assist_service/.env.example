# ==============================================================================
# Isaac Assist Service Configuration Defaults
# Copy this file to .env and modify as needed.
# ==============================================================================

# ── LLM Provider Mode ─────────────────────────────────────────────────────────
# "local" = Ollama / Local vLLM instance
# "cloud" = Gemini Cloud / Google GenAI
LLM_MODE=local

# ── Local Models ──────────────────────────────────────────────────────────────
# Ensure this model is pulled and available via `ollama list`
LOCAL_MODEL_NAME=qwen3.6:latest

# ── Cloud Models ──────────────────────────────────────────────────────────────
CLOUD_MODEL_NAME=gemini-1.5-pro-latest
API_KEY_GEMINI=your_gemini_api_key_here

# ── LiveKit Self-Hosted Configuration ─────────────────────────────────────────
# Pointing to the internal `infra/` docker-compose stack by default.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── Cosmos 3 Scene Proposals (Optional) ──────────────────────────────────────
# The current backend accepts structured CosmosSceneObservation JSON and turns it
# into a reviewable floor-plan LayoutSpec. Runtime model invocation can be wired
# to local, NIM, or vLLM services using these placeholders.
# COSMOS3_MODE=disabled
# COSMOS3_REASONER_BASE_URL=http://localhost:8081/v1
# COSMOS3_REASONER_MODEL=Cosmos3-Nano
# COSMOS3_API_KEY=your_cosmos_or_ngc_api_key_here
# COSMOS3_GENERATOR_BASE_URL=http://localhost:8082/v1
# COSMOS3_GENERATOR_MODEL=Cosmos3-Super-Text2Image

# ── Remote Scale Providers (Optional) ────────────────────────────────────────
# ISAAC_ASSIST_SCALE_PROVIDER=local
# DGX_SPARK_COSMOS_BASE_URL=http://dgx-spark.local:8081/v1
# BREV_API_KEY=your_brev_api_key_here
# BREV_PROJECT_ID=your_brev_project_id_here
# BREV_TEMPLATE_ID=your_brev_template_id_here
# ISAAC_AUTOMATOR_ROOT=/path/to/IsaacAutomator
# ISAAC_AUTOMATOR_CLOUD=aws
# ISAAC_AUTOMATOR_DEPLOYMENT=isaac-assist-remote
# ISAAC_AUTOMATOR_ISAACSIM_REF=v6.0.0-dev2
# ISAAC_AUTOMATOR_ISAACLAB_REF=v3.0.0-beta

# ── Assets ────────────────────────────────────────────────────────────────────
# Local path or Nucleus URL to Isaac Sim assets (robots, environments, etc.)
# See .env.local.example in the repo root for detailed setup instructions.
# ASSETS_ROOT_PATH=/path/to/your/assets
# ASSETS_ROBOTS_SUBDIR=Collected_Robots

# ── Rendering Mode Control (Optional) ────────────────────────────────────────
# Accepted values: fast | real
ISAAC_ASSIST_RENDERING_MODE=real
# Optional JSON control-file path for runtime loops that consume this setting.
# ISAAC_ASSIST_RENDER_CONTROL_FILE=/path/to/rendering_mode.json

# ── Isaac Lab ─────────────────────────────────────────────────────────────────
# Path to the IsaacLab root directory (contains isaaclab.sh).
# Used by deploy_rl_policy to launch locomotion policies.
ISAACLAB_PATH=/path/to/IsaacLab
