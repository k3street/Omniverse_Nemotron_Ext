# ==============================================================================
# Isaac Assist Service Configuration Defaults
# Copy this file to .env and modify as needed.
# ==============================================================================

# ── LLM Provider Mode ─────────────────────────────────────────────────────────
# "local" = Ollama / Local vLLM instance
# "cloud" = Gemini Cloud / Google GenAI
LLM_MODE=local

# ── Local Models ──────────────────────────────────────────────────────────────
# Ensure this model is pulled and available via `ollama list`
LOCAL_MODEL_NAME=cosmos-reason-2:latest

# ── Cloud Models ──────────────────────────────────────────────────────────────
CLOUD_MODEL_NAME=gemini-1.5-pro-latest
API_KEY_GEMINI=your_gemini_api_key_here

# ── LiveKit Self-Hosted Configuration ─────────────────────────────────────────
# Pointing to the internal `infra/` docker-compose stack by default.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── Assets ────────────────────────────────────────────────────────────────────
# Local path or Nucleus URL to Isaac Sim assets (robots, environments, etc.)
# See .env.local.example in the repo root for detailed setup instructions.
# ASSETS_ROOT_PATH=/path/to/your/assets
# ASSETS_ROBOTS_SUBDIR=Collected_Robots

# ── Isaac Lab ─────────────────────────────────────────────────────────────────
# Path to the IsaacLab root directory (contains isaaclab.sh).
# Used by deploy_rl_policy to launch locomotion policies.
ISAACLAB_PATH=/home/kimate/Documents/Github/open_arm_10Things/IsaacLab
